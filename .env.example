# ==============================================================================
# NEXUS 2.0 Agentic OS — Environment Configuration Template
# ==============================================================================

# --- Server / Runtime ---
PORT=9900                                   # Server HTTP listening port (default: 9900)
NODE_ENV=production                          # Environment mode ('development', 'production', 'test')

# --- Security & CORS ---
NEXUS_API_KEY=nk_live_change_me_in_prod    # Master operator API key hash seed
NEXUS_ALLOWED_ORIGINS=http://frontend:80,http://127.0.0.1:80,http://127.0.0.1:9900 # Production CORS origins (no localhost or '*' allowed in production)
NEXUS_RATE_LIMIT_PER_MINUTE=120             # Maximum requests allowed per principal per minute
NEXUS_MAX_BODY_BYTES=5242880                # Maximum request body size in bytes (default: 5MB)
NEXUS_LOG_LEVEL=info                        # Logging level: 'debug', 'info', 'warn', 'error'
NEXUS_LOG_ERRORS=1                          # Enable detailed error logging (1 = enabled, 0 = disabled)
NEXUS_TRUST_PROXY=false                     # Trust reverse proxy X-Forwarded-* headers

# --- Database & Storage ---
# PostgreSQL connection string for production persistence.
# Leave empty to run in lightweight embedded SQLite mode.
DATABASE_URL=postgresql://postgres:nexus_password@postgres:5432/nexus
NEXUS_DB_POOL_MAX=20                        # Maximum database connections in pool
NEXUS_QUERY_TIMEOUT_MS=15000                # Database query execution timeout in milliseconds

# --- Message Bus & Cache ---
# Bus backend: 'memory' for single node, 'redis' for distributed agent messaging
NEXUS_BUS_BACKEND=redis
NEXUS_REDIS_URL=redis://redis:6379           # Redis connection URL for bus and caching

# --- LLM / AI Providers ---
# Primary LLM Endpoint & Key (Optional — system falls back to lexical routing if unset)
NEXUS_LLM_BASE_URL=
NEXUS_LLM_API_KEY=
NEXUS_LLM_MODEL=
NEXUS_EMBEDDING_MODEL=

# Additional Provider Keys (Optional)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=
MISTRAL_API_KEY=

# --- Vector Embedding & Memory Recall ---
NEXUS_EMBEDDING_DIM=1536                    # Embedding vector dimensions
NEXUS_EMBEDDING_BATCH_SIZE=64               # Batch size for generating embeddings
NEXUS_RRF_K=60                              # Reciprocal Rank Fusion constant
NEXUS_SEMANTIC_THRESHOLD=0.8                # Similarity threshold for vector recall
NEXUS_RECENCY_HALFLIFE_DAYS=30              # Memory recency decay half-life in days

# --- Scheduler & Background Worker ---
NEXUS_WORKER_POLL_MS=2000                   # Task worker polling frequency (ms)
NEXUS_WORKER_MAX_CONCURRENCY=3             # Max parallel task executions per worker
NEXUS_WORKER_TIMEOUT_MS=120000              # Max task execution time before timeout
NEXUS_SCHEDULER_TICK_MS=60000               # Maintenance task cron tick interval

# --- OpenTelemetry Tracing ---
NEXUS_OTEL_ENDPOINT=                        # OTLP collector gRPC/HTTP endpoint URL
NEXUS_OTEL_API_KEY=                         # Optional OTLP collector authentication token

# --- Blockchain Anchoring ---
NEXUS_BLOCKCHAIN_ENABLED=false
NEXUS_BLOCKCHAIN_RPC_URL=
NEXUS_BLOCKCHAIN_PRIVATE_KEY=
NEXUS_BLOCKCHAIN_ENCRYPTION_KEY=            # Must be set if NEXUS_BLOCKCHAIN_PRIVATE_KEY is a raw (unencrypted) private key.
NEXUS_BLOCKCHAIN_CHAIN_ID=1
NEXUS_BLOCKCHAIN_ANCHOR_INTERVAL=10
