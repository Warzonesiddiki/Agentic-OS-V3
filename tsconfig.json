{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "declaration": true,
    "outDir": "./dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "paths": {
      "@agentic-os/sdk": ["./packages/sdk/src"],
      "@agentic-os/sdk/*": ["./packages/sdk/src/*"],
      "@agentic-os/devtools": ["./packages/devtools/src"],
      "@agentic-os/devtools/*": ["./packages/devtools/src/*"],
      "@agentic-os/a2a-server": ["./packages/a2a-server/src"],
      "@agentic-os/a2a-server/*": ["./packages/a2a-server/src/*"]
    }
  },
  "include": ["packages/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true
  },
  "include": ["server/src/**/*.ts"]
}
