# --- Server / runtime ---
PORT=9900
NODE_ENV=development

# --- Database (target server port; unused by the in-browser build) ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/nexus
NEXUS_DB_POOL_MAX=20
NEXUS_QUERY_TIMEOUT_MS=15000

# --- Security ---
NEXUS_API_KEY=
NEXUS_ALLOWED_ORIGINS=http://localhost:9900
NEXUS_RATE_LIMIT_PER_MINUTE=120
NEXUS_MAX_BODY_BYTES=5242880
NEXUS_LOG_LEVEL=info
NEXUS_LOG_ERRORS=1

# --- LLM / embeddings (optional; lexical fallback if unset) ---
NEXUS_LLM_BASE_URL=
NEXUS_LLM_API_KEY=
NEXUS_LLM_MODEL=
NEXUS_EMBEDDING_MODEL=

# --- Obsidian vault (optional) ---
NEXUS_OBSIDIAN_VAULT=

# --- Dream job caps (optional) ---
NEXUS_DREAM_MAX_MEMORIES=500
NEXUS_DREAM_MAX_SESSIONS=20
NEXUS_DREAM_TIMEOUT_MS=60000

# --- Redis (optional; NEXUS_BUS_BACKEND must be "redis") ---
NEXUS_REDIS_URL=redis://localhost:6379
NEXUS_BUS_BACKEND=memory

# --- OpenTelemetry (optional) ---
NEXUS_OTEL_ENDPOINT=
NEXUS_OTEL_API_KEY=

# --- Blockchain anchoring (optional) ---
NEXUS_BLOCKCHAIN_ENABLED=false
NEXUS_BLOCKCHAIN_RPC_URL=
NEXUS_BLOCKCHAIN_PRIVATE_KEY=
NEXUS_BLOCKCHAIN_CHAIN_ID=1
NEXUS_BLOCKCHAIN_ANCHOR_INTERVAL=10
