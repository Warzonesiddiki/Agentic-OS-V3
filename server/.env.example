PORT=9900
NODE_ENV=development

# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/nexus

# Security
NEXUS_API_KEY=
NEXUS_ALLOWED_ORIGINS=http://localhost:9900
NEXUS_RATE_LIMIT_PER_MINUTE=120
NEXUS_MAX_BODY_BYTES=5242880
NEXUS_LOG_LEVEL=info
NEXUS_LOG_ERRORS=1

# LLM / embeddings (optional — lexical fallback if unset)
NEXUS_LLM_BASE_URL=
NEXUS_LLM_API_KEY=
NEXUS_LLM_MODEL=
NEXUS_EMBEDDING_MODEL=

# Obsidian vault (optional)
NEXUS_OBSIDIAN_VAULT=

# Pool / query
NEXUS_DB_POOL_MAX=20
NEXUS_QUERY_TIMEOUT_MS=15000

# Trust X-Forwarded-* headers (set true only behind a known reverse proxy)
NEXUS_TRUST_PROXY=false
# MCP config origin printed by `nexus mcp-config`
NEXUS_MCP_ORIGIN=http://localhost:9900
# Directory of the built dashboard (served at / by the API server)
NEXUS_DASHBOARD_DIR=../dist

# Dream job caps
NEXUS_DREAM_MAX_MEMORIES=500
NEXUS_DREAM_MAX_SESSIONS=20
NEXUS_DREAM_TIMEOUT_MS=60000

# Phase 5: Sandbox (optional — for ephemeral Docker code execution)
NEXUS_SANDBOX_ENABLED=false
NEXUS_SANDBOX_IMAGE=node:20-alpine
NEXUS_SANDBOX_TIMEOUT_MS=30000

# Phase 3: Scheduler tick interval (ms) — how often cron jobs are checked
NEXUS_SCHEDULER_TICK_MS=60000

# Embedding config
NEXUS_EMBEDDING_DIM=1536
NEXUS_EMBEDDING_BATCH_SIZE=64

# Auth cache config
NEXUS_AUTH_PRINCIPAL_TTL_MS=30000
NEXUS_AUTH_RESULT_TTL_MS=60000
NEXUS_AUTH_RESULT_CACHE_CAP=1024

# Recall config
NEXUS_RRF_K=60
NEXUS_SEMANTIC_THRESHOLD=0.8
NEXUS_RECENCY_HALFLIFE_DAYS=30
NEXUS_RECALL_WEIGHT_RRF=0.5
NEXUS_RECALL_WEIGHT_IMPORTANCE=0.3
NEXUS_RECALL_WEIGHT_RECENCY=0.1
NEXUS_RECALL_WEIGHT_FEEDBACK=0.1

# Skill compiler config
NEXUS_COMPILATION_THRESHOLD=5
NEXUS_EVAL_MATCH_THRESHOLD=1.0

# Circuit breaker config
NEXUS_CB_THRESHOLD=3
NEXUS_CB_RESET_MS=30000

# Recall corpus cap (prevent OOM on large datasets)
NEXUS_MAX_RECALL_CORPUS=10000

# Worker defaults
NEXUS_WORKER_POLL_MS=2000
NEXUS_WORKER_MAX_CONCURRENCY=3
NEXUS_WORKER_TIMEOUT_MS=120000
NEXUS_WORKER_MAINTENANCE_MS=60000
NEXUS_WORKER_STALE_TASK_MS=300000
NEXUS_WORKER_HEARTBEAT_MS=120000
NEXUS_WORKER_AUTO_KILL=false
