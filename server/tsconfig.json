{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "types": ["node"],
    "outDir": "dist",
    "rootDir": ".",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "esModuleInterop": true,
    "downlevelIteration": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": false,
    "sourceMap": true,
    "paths": {
      "@agentic-os/sdk": ["../packages/sdk/src"],
      "@agentic-os/sdk/*": ["../packages/sdk/src/*"],
      "@agentic-os/devtools": ["../packages/devtools/src"],
      "@agentic-os/devtools/*": ["../packages/devtools/src/*"],
      "@agentic-os/a2a-server": ["../packages/a2a-server/src"],
      "@agentic-os/a2a-server/*": ["../packages/a2a-server/src/*"]
    }
  },
  "include": ["src", "tests"],
  "exclude": ["node_modules", "dist"]
}
