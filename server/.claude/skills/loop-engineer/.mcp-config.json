{
  "mcpServers": {
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": { "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_TOKEN}" },
      "priority": "critical"
    },
    "filesystem": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "."],
      "priority": "critical"
    },
    "git": {
      "command": "uvx",
      "args": ["mcp-server-git", "--repository", "."],
      "priority": "critical"
    },
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp"],
      "priority": "critical"
    },
    "memory": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-memory"],
      "priority": "high"
    },
    "postgres": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-postgres"],
      "env": { "POSTGRES_CONNECTION_STRING": "${POSTGRES_URL}" },
      "priority": "high"
    },
    "sqlite": {
      "command": "uvx",
      "args": ["mcp-server-sqlite", "--db-path", "./db.sqlite"],
      "priority": "high"
    },
    "docker": {
      "command": "uvx",
      "args": ["mcp-server-docker"],
      "priority": "critical"
    },
    "kubernetes": {
      "command": "npx",
      "args": ["-y", "kubectl-mcp-server"],
      "priority": "critical"
    },
    "playwright": {
      "command": "npx",
      "args": ["-y", "@playwright/mcp"],
      "priority": "critical"
    },
    "fetch": {
      "command": "uvx",
      "args": ["mcp-server-fetch"],
      "priority": "high"
    },
    "snyk": {
      "command": "npx",
      "args": ["-y", "snyk-cli-mcp"],
      "env": { "SNYK_TOKEN": "${SNYK_TOKEN}" },
      "priority": "critical"
    },
    "semgrep": {
      "command": "uvx",
      "args": ["semgrep-mcp"],
      "priority": "high"
    },
    "sandbox": {
      "command": "npx",
      "args": ["-y", "sandbox-mcp"],
      "priority": "critical"
    },
    "sonarqube": {
      "command": "npx",
      "args": ["-y", "sonarqube-mcp"],
      "env": { "SONAR_TOKEN": "${SONAR_TOKEN}", "SONAR_URL": "${SONAR_URL}" },
      "priority": "high"
    },
    "slack": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-slack"],
      "env": { "SLACK_BOT_TOKEN": "${SLACK_BOT_TOKEN}" },
      "priority": "high"
    },
    "jira": {
      "command": "npx",
      "args": ["-y", "atlassian-mcp"],
      "env": { "ATLASSIAN_TOKEN": "${ATLASSIAN_TOKEN}" },
      "priority": "high"
    },
    "grafana": {
      "command": "npx",
      "args": ["-y", "grafana-mcp"],
      "env": { "GRAFANA_TOKEN": "${GRAFANA_TOKEN}", "GRAFANA_URL": "${GRAFANA_URL}" },
      "priority": "high"
    },
    "brave_search": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-brave-search"],
      "env": { "BRAVE_API_KEY": "${BRAVE_API_KEY}" },
      "priority": "high"
    },
    "firecrawl": {
      "command": "npx",
      "args": ["-y", "firecrawl-mcp"],
      "env": { "FIRECRAWL_API_KEY": "${FIRECRAWL_API_KEY}" },
      "priority": "high"
    },
    "openapi": {
      "command": "npx",
      "args": ["-y", "openapi-mcp"],
      "priority": "high"
    },
    "postman": {
      "command": "npx",
      "args": ["-y", "postman-mcp"],
      "env": { "POSTMAN_API_KEY": "${POSTMAN_API_KEY}" },
      "priority": "high"
    },
    "terraform": {
      "command": "npx",
      "args": ["-y", "terraform-mcp"],
      "priority": "high"
    },
    "vercel": {
      "command": "npx",
      "args": ["-y", "vercel-mcp"],
      "env": { "VERCEL_TOKEN": "${VERCEL_TOKEN}" },
      "priority": "high"
    },
    "cloudflare": {
      "command": "npx",
      "args": ["-y", "@cloudflare/mcp-server-cloudflare"],
      "env": { "CLOUDFLARE_API_TOKEN": "${CF_TOKEN}" },
      "priority": "high"
    },
    "task_mgmt": {
      "command": "npx",
      "args": ["-y", "task-mgmt-mcp"],
      "priority": "high"
    }
  },
  "security": {
    "vet_all_servers": true,
    "require_oauth_for_external": true,
    "never_log_tokens": true,
    "credential_isolation": true,
    "ssrf_protection": true
  }
}