{
  "name": "nexus-2-server",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "description": "NEXUS 2.0 — production-grade second brain & MCP server for AI agents",
  "bin": {
    "nexus": "dist/cli.js"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "cli": "tsx src/cli.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\"",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "validate": "npm run lint && npm run typecheck && npm test && npm run test:integration && npm run build"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@modelcontextprotocol/sdk": "^1.0.4",
    "cron-parser": "^5.6.1",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.36.4",
    "hono": "^4.6.14",
    "ioredis": "^5.11.1",
    "postgres": "^3.4.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.2",
    "drizzle-kit": "^0.28.1",
    "eslint": "^9.17.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20"
  }
}
