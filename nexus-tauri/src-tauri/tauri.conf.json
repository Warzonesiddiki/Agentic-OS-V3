{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Nexus Agentic OS",
  "version": "2.0.0",
  "identifier": "com.yourcompany.nexus",
  "build": {
    "beforeDevCommand": "npm run dev -- --port 1422",
    "devUrl": "http://localhost:1422",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Nexus Agentic OS",
        "width": 1280,
        "height": 900
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:*;"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/backend"
    ]
  }
}